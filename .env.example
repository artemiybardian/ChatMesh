# PostgreSQL
POSTGRES_USER=chatmesh
POSTGRES_PASSWORD=chatmesh_secret
POSTGRES_DB=chatmesh_auth

# RabbitMQ
RABBITMQ_USER=chatmesh
RABBITMQ_PASS=chatmesh_secret

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8001
NEXT_PUBLIC_CHAT_API_URL=http://localhost:8002
NEXT_PUBLIC_WS_URL=ws://localhost:8003
NEXT_PUBLIC_NOTIFICATIONS_API_URL=http://localhost:8004
